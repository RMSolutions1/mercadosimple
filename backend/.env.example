# Base de datos (local o DATABASE_URL en producción)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=mercadosimple
DB_PASSWORD=mercadosimple123
DB_DATABASE=mercadosimple
DB_SSL=false
# En Fly.io se usa DATABASE_URL (Postgres Managed)

# JWT (producción: generar con openssl rand -base64 64)
JWT_SECRET=reemplazar-con-secreto-seguro
JWT_REFRESH_SECRET=reemplazar-con-otro-secreto-seguro
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URLs de la app
APP_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3000

# Email — Opción 1: Resend (recomendado para producción)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM="Mercado Simple <onboarding@resend.dev>"

# Email — Opción 2: SMTP
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Mercado Simple <noreply@tudominio.com>"

# Mercado Pago (producción: token real, no TEST-)
# MP_ACCESS_TOKEN=APP_USR-xxxx
# MP_PUBLIC_KEY=APP_USR-xxxx

# Opcional: sincronizar esquema en producción (por defecto false)
# ALLOW_SYNC=false
