# ============================================================
#  MERCADO SIMPLE — Variables de entorno para producción
#  Copiar como .env y completar cada valor
# ============================================================

# ── Base de datos ───────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=mercadosimple
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
DB_DATABASE=mercadosimple
DB_SSL=false

# ── JWT ─────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_POR_SECRET_ALEATORIO_MIN_64_CHARS
JWT_REFRESH_SECRET=CAMBIAR_POR_REFRESH_SECRET_ALEATORIO_MIN_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=https://mercadosimple.com.ar
APP_URL=https://mercadosimple.com.ar
NEXT_PUBLIC_API_URL=https://api.mercadosimple.com.ar/api
NEXT_PUBLIC_APP_URL=https://mercadosimple.com.ar

# ── Email SMTP ───────────────────────────────────────────────
# Recomendado: Resend (resend.com), Mailgun o SES
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=CAMBIAR_POR_API_KEY_SMTP
SMTP_FROM="Mercado Simple" <noreply@mercadosimple.com.ar>

# ── Mercado Pago ─────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers
MP_ACCESS_TOKEN=APP_USR-CAMBIAR_POR_TOKEN_PRODUCCION
MP_PUBLIC_KEY=APP_USR-CAMBIAR_POR_PUBLIC_KEY

# ── pgAdmin (solo dev) ───────────────────────────────────────
PGADMIN_PASSWORD=Admin123
